# Backend Ventas — variables de entorno
# Copiar a .env y completar valores. NO commitear el .env real.

# Conexión Postgres (incluyendo schema search_path)
DATABASE_URL=postgres://USUARIO:PASSWORD@HOST:PUERTO/datos?sslmode=disable&options=-csearch_path%3Dpublic,odoo,produccion

# Clave para firmar JWT. Generar con: openssl rand -hex 32
JWT_SECRET_KEY=cambiar-en-produccion

# Orígenes permitidos por CORS. "*" = cualquier dominio.
# En producción especificar el dominio del frontend, ej:
# CORS_ORIGINS=https://ventas.midominio.com,https://app.midominio.com
CORS_ORIGINS=*
