# Frontend Ventas — variables de entorno (build-time)
# CRA inyecta REACT_APP_* en el bundle al hacer `npm run build`.
# Cambiar el valor requiere RECONSTRUIR la imagen, no solo reiniciar.

# URL pública del backend, sin trailing slash. El frontend le agrega /api.
# Ejemplos:
#   Local:       http://localhost:8003
#   EasyPanel:   https://api.ventas.midominio.com
REACT_APP_BACKEND_URL=http://localhost:8003

# Puerto del dev server (solo para `npm start`, no aplica al build prod)
PORT=3003
